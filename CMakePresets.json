{
  "version": 3,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 21,
    "patch": 1
  },
  "configurePresets": [
    {
      "name": "pico2-spi-i2c-fas5600-sas5600-gpslc76g-release",
      "displayName": "Pico 2 W (Release): SPI SD, I2C Disp, AS5600/AS5600 Sensors, GPS:LC76G",
      "binaryDir": "${sourceDir}/build/pico2-spi-i2c-fas5600-sas5600-gpslc76g-release",
      "cacheVariables": {
        "PICO_BOARD": "pico2_w",
        "GPS_MODULE": "LC76G",
        "SPI_MICROSD": "ON",
        "DISP_PROTO": "PIO_I2C",
        "FORK_LINEAR": "OFF",
        "SHOCK_LINEAR": "OFF",
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "pico2-spi-i2c-fas5600-sas5600-gpslc76g-debug",
      "displayName": "Pico 2 W (Debug): SPI SD, I2C Disp, AS5600/AS5600 Sensors, GPS:LC76G",
      "binaryDir": "${sourceDir}/build/pico2-spi-i2c-fas5600-sas5600-gpslc76g-debug",
      "cacheVariables": {
        "PICO_BOARD": "pico2_w",
        "GPS_MODULE": "LC76G",
        "SPI_MICROSD": "ON",
        "DISP_PROTO": "PIO_I2C",
        "FORK_LINEAR": "OFF",
        "SHOCK_LINEAR": "OFF",
        "CMAKE_BUILD_TYPE": "Debug"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "pico2-spi-i2c-fas5600-sas5600-gpslc76g-release",
      "configurePreset": "pico2-spi-i2c-fas5600-sas5600-gpslc76g-release"
    },
    {
      "name": "pico2-spi-i2c-fas5600-sas5600-gpslc76g-debug",
      "configurePreset": "pico2-spi-i2c-fas5600-sas5600-gpslc76g-debug"
    }
  ]
}